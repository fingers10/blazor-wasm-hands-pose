@page "/attendance"
@inject IHttpClientFactory HttpFactory

<PageTitle>Attendance &mdash; Face Mesh</PageTitle>

<h3>&#x1F4CB; Attendance Check-In</h3>
<p class="text-muted">
    Face the camera. Recognised people are marked automatically every 1.5 s.
    <br />
    <small>Note: the first few seconds are used to calibrate the recognition threshold.
    If you get many false negatives, try re-enrolling with the same lighting.</small>
</p>

<div class="mb-3" style="max-width:420px">
    <label class="form-label fw-semibold">&#x1F6E1;&#xFE0F; Liveness mode</label>
    <select class="form-select" @bind="_livenessMode" @bind:after="OnLivenessModeChanged">
        <option value="none">None &mdash; no liveness check</option>
        <option value="blink">Blink &mdash; active challenge (blink required)</option>
        <option value="depth">Z-depth &mdash; passive check, detects flat photos/screens</option>
        <option value="both">Both &mdash; Z-depth (passive) then Blink (active)</option>
    </select>
</div>

@if (_recognitionMessage != null)
{
    <div class="alert @_recognitionCss mb-3">@_recognitionMessage</div>
}

<FaceMesh @ref="_face"
          Mode="checkin"
          LivenessMode="@_livenessMode"
          OnFeatureVectorCaptured="HandleCheckin" />

@if (_todayRecords.Count > 0)
{
    <h5 class="mt-4">Today&rsquo;s check-ins (@_todayRecords.Count)</h5>
    <table class="table table-sm table-striped" style="max-width:480px">
        <thead><tr><th>Name</th><th>Time (UTC)</th><th>Distance</th></tr></thead>
        <tbody>
            @foreach (var r in _todayRecords)
            {
                <tr>
                    <td>@r.PersonName</td>
                    <td>@r.CheckedInAt.ToString("HH:mm:ss")</td>
                    <td><small class="text-muted">@r.Distance.ToString("F3")</small></td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted mt-3">No check-ins yet today.</p>
}

@code {
    private FaceMesh? _face;
    private string _livenessMode = "blink";
    private string? _recognitionMessage;
    private string _recognitionCss = "alert-success";
    private List<AttendanceRecordDto> _todayRecords = new();
    private bool _processing;

    protected override async Task OnInitializedAsync() => await LoadTodayAttendance();

    private void OnLivenessModeChanged() => _face?.SetLivenessMode(_livenessMode);

    private async void HandleCheckin(FeatureVectorResult result)
    {
        if (!result.Detected || result.Vector is null || _processing) return;
        if (_livenessMode != "none" && !(_face?.LivenessConfirmed ?? false)) return;

        _processing = true;
        try
        {
            var http     = HttpFactory.CreateClient("facemesh");
            var payload  = new { vector = result.Vector };
            var response = await http.PostAsJsonAsync("/api/mesh/attendance/checkin", payload);

            if (response.IsSuccessStatusCode)
            {
                var data = await response.Content.ReadFromJsonAsync<CheckInResponseDto>();
                if (data?.Recognized == true)
                {
                    _face?.ResetLiveness();
                    _recognitionMessage = $"\u2705 Welcome, {data.PersonName}! Attendance marked. (distance: {data.Distance:F3})";
                    _recognitionCss     = "alert-success";
                    await LoadTodayAttendance();
                }
                else
                {
                    _recognitionMessage = $"\u2753 Face not recognised (distance: {data?.Distance:F3}). Please enrol first.";
                    _recognitionCss     = "alert-warning";
                }
            }
        }
        catch (Exception ex)
        {
            _recognitionMessage = $"\u274C API error: {ex.Message}";
            _recognitionCss     = "alert-danger";
        }
        finally { _processing = false; StateHasChanged(); }
    }

    private async Task LoadTodayAttendance()
    {
        try
        {
            var http = HttpFactory.CreateClient("facemesh");
            var list = await http.GetFromJsonAsync<List<AttendanceRecordDto>>("/api/mesh/attendance");
            _todayRecords = list ?? new();
        }
        catch { /* API not yet running */ }
    }

    private record CheckInResponseDto(bool Recognized, Guid? PersonId, string? PersonName, float Distance);
    private record AttendanceRecordDto(Guid Id, Guid PersonId, string PersonName, DateTime CheckedInAt, float Distance = 0);
}
