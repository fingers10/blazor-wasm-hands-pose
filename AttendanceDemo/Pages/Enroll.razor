@page "/enroll"
@using DetectFaceJsComponent
@inject IHttpClientFactory HttpFactory

<PageTitle>Enroll Face</PageTitle>

<h3>&#x1F9CD; Enroll a New Person</h3>
<p class="text-muted">Position your face in the camera, click <strong>Capture Face</strong>, then enter your name and register.</p>

<DetectFace @ref="_face" Mode="enroll" OnDescriptorCaptured="HandleCapture" />

@if (_capturedDescriptor != null)
{
    <div class="card mt-3" style="max-width:480px">
        <div class="card-body">
            <h5 class="card-title">&#x2705; Face captured &mdash; @_capturedSampleCount sample@(_capturedSampleCount == 1 ? "" : "s") averaged</h5>
            <div class="mb-3">
                <label class="form-label" for="personName">Full name</label>
                <input id="personName" class="form-control" placeholder="e.g. Jane Smith"
                       @bind="_personName" @bind:event="oninput" />
            </div>
            <button class="btn btn-success" @onclick="RegisterPerson"
                    disabled="@(string.IsNullOrWhiteSpace(_personName) || _busy)">
                @(_busy ? "Registering…" : "Register")
            </button>
            @if (_statusMessage != null)
            {
                <div class="alert @_statusCss mt-2 mb-0">@_statusMessage</div>
            }
        </div>
    </div>
}

@if (_enrolled.Count > 0)
{
    <h5 class="mt-4">Enrolled people (@_enrolled.Count)</h5>
    <table class="table table-sm table-striped" style="max-width:480px">
        <thead><tr><th>Name</th><th>Enrolled at (UTC)</th></tr></thead>
        <tbody>
            @foreach (var p in _enrolled)
            {
                <tr>
                    <td>@p.Name</td>
                    <td>@p.EnrolledAt.ToString("yyyy-MM-dd HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private DetectFace? _face;
    private float[]? _capturedDescriptor;
    private int _capturedSampleCount;
    private string _personName = "";
    private bool _busy;
    private string? _statusMessage;
    private string _statusCss = "alert-success";
    private List<EnrolledPersonDto> _enrolled = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadEnrolled();
    }

    private void HandleCapture(DescriptorResult result)
    {
        if (result.Detected && result.Descriptor != null)
        {
            _capturedDescriptor = result.Descriptor;
            _capturedSampleCount = result.SampleCount;
            _statusMessage = null;
        }
        else
        {
            _statusMessage = "No face detected — please look at the camera and try again.";
            _statusCss = "alert-warning";
            StateHasChanged();
        }
    }

    private async Task RegisterPerson()
    {
        if (_capturedDescriptor is null || string.IsNullOrWhiteSpace(_personName)) return;

        _busy = true;
        _statusMessage = null;
        StateHasChanged();

        try
        {
            var http = HttpFactory.CreateClient("attendance");
            var payload = new { name = _personName.Trim(), descriptor = _capturedDescriptor };
            var response = await http.PostAsJsonAsync("/api/persons/enroll", payload);

            if (response.IsSuccessStatusCode)
            {
                _statusMessage = $"✅ {_personName.Trim()} registered successfully!";
                _statusCss = "alert-success";
                _personName = "";
                _capturedDescriptor = null;
                await LoadEnrolled();
            }
            else
            {
                _statusMessage = $"❌ Registration failed: {response.ReasonPhrase}";
                _statusCss = "alert-danger";
            }
        }
        catch (Exception ex)
        {
            _statusMessage = $"❌ Error: {ex.Message}";
            _statusCss = "alert-danger";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task LoadEnrolled()
    {
        try
        {
            var http = HttpFactory.CreateClient("attendance");
            var list = await http.GetFromJsonAsync<List<EnrolledPersonDto>>("/api/persons");
            _enrolled = list ?? new();
        }
        catch { /* API not running yet — silently ignore */ }
    }

    private record EnrolledPersonDto(Guid Id, string Name, DateTime EnrolledAt);
}
