@page "/attendance"
@using DetectFaceJsComponent
@inject IHttpClientFactory HttpFactory

<PageTitle>Attendance</PageTitle>

<h3>&#x1F4CB; Attendance Check-In</h3>
<p class="text-muted">Face the camera — recognised people are marked automatically.</p>
<div class="mb-3" style="max-width:420px">
    <label class="form-label fw-semibold">&#x1F6E1;&#xFE0F; Liveness detection</label>
    <select class="form-select" @bind="_livenessMode" @bind:after="OnLivenessModeChanged">
        <option value="none">None &mdash; no liveness check</option>
        <option value="blink">Layer 1 &mdash; Blink detection (EAR, zero dependencies)</option>
        <option value="minifasnet">Layer 2 &mdash; Anti-spoof AI model (MiniFASNet ONNX)</option>
    </select>
</div>
@if (_recognitionMessage != null)
{
    <div class="alert @_recognitionCss mb-3">@_recognitionMessage</div>
}

<DetectFace @ref="_face" Mode="checkin" LivenessMode="@_livenessMode" OnDescriptorCaptured="HandleCheckin" />

@if (_todayRecords.Count > 0)
{
    <h5 class="mt-4">Today&rsquo;s attendance (@_todayRecords.Count)</h5>
    <table class="table table-sm table-striped" style="max-width:480px">
        <thead><tr><th>Name</th><th>Checked in at (UTC)</th></tr></thead>
        <tbody>
            @foreach (var r in _todayRecords)
            {
                <tr>
                    <td>@r.PersonName</td>
                    <td>@r.CheckedInAt.ToString("HH:mm:ss")</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted mt-3">No check-ins yet today.</p>
}

@code {
    private DetectFace? _face;
    private string _livenessMode = "blink";
    private string? _recognitionMessage;
    private string _recognitionCss = "alert-success";
    private List<AttendanceRecordDto> _todayRecords = new();
    private bool _processing;

    private void OnLivenessModeChanged()
    {
        _face?.SetLivenessMode(_livenessMode);
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadTodayAttendance();
    }

    private async void HandleCheckin(DescriptorResult result)
    {
        if (!result.Detected || result.Descriptor is null || _processing) return;

        // C#-level liveness gate — block check-in if liveness mode is active but not confirmed
        if (_livenessMode != "none" && !(_face?.LivenessConfirmed ?? false)) return;

        _processing = true;
        try
        {
            var http = HttpFactory.CreateClient("attendance");
            var payload = new { descriptor = result.Descriptor };
            var response = await http.PostAsJsonAsync("/api/attendance/checkin", payload);

            if (response.IsSuccessStatusCode)
            {
                var data = await response.Content.ReadFromJsonAsync<CheckInResponseDto>();
                if (data?.Recognized == true)
                {
                    _face?.SetRecognizedName(data.PersonName);
                    _face?.ResetLiveness();  // require fresh liveness proof for next check-in
                    _recognitionMessage = $"✅ Welcome, {data.PersonName}! Attendance marked.";
                    _recognitionCss = "alert-success";
                    await LoadTodayAttendance();
                }
                else
                {
                    _face?.SetRecognizedName("?");
                    _recognitionMessage = "❓ Face not recognised — please enrol first.";
                    _recognitionCss = "alert-warning";
                }
            }
        }
        catch (Exception ex)
        {
            _recognitionMessage = $"❌ Error contacting API: {ex.Message}";
            _recognitionCss = "alert-danger";
        }
        finally
        {
            _processing = false;
            StateHasChanged();
        }
    }

    private async Task LoadTodayAttendance()
    {
        try
        {
            var http = HttpFactory.CreateClient("attendance");
            var list = await http.GetFromJsonAsync<List<AttendanceRecordDto>>("/api/attendance");
            _todayRecords = list ?? new();
        }
        catch { /* API not running — silently ignore */ }
    }

    private record CheckInResponseDto(bool Recognized, Guid? PersonId, string? PersonName, float Distance);
    private record AttendanceRecordDto(Guid Id, Guid PersonId, string PersonName, DateTime CheckedInAt);
}
